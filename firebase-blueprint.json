{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User statistics and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "sessions": { "type": "integer" },
        "minutes": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastDate": { "type": "string" },
        "explored": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dailyCount": {
          "type": "object",
          "properties": {
            "date": { "type": "string" },
            "count": { "type": "integer" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "Daily journal data for a specific week or day",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dayIndex": { "type": "integer" },
        "checked": {
          "type": "object",
          "properties": {
            "body": { "type": "boolean" },
            "breath": { "type": "boolean" },
            "focus": { "type": "boolean" },
            "space": { "type": "boolean" }
          }
        },
        "comfort": { "type": "integer", "minimum": 1, "maximum": 5 },
        "tags": { "type": "string" },
        "tensions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "note": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date"]
    },
    "MoodEntry": {
      "title": "Mood Entry",
      "description": "Daily mood tracker",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "val": { "type": "integer", "minimum": 0, "maximum": 4 },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user document for global stats"
    },
    "/users/{userId}/journal/{entryId}": {
      "schema": "JournalEntry",
      "description": "Journal entries per user. entryId is typically the date."
    },
    "/users/{userId}/moods/{moodId}": {
      "schema": "MoodEntry",
      "description": "Daily mood entries. moodId is the date."
    }
  }
}
